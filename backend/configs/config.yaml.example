# opslabs 本地开发样例配置
#
# 安全约定:
#   - 这个文件是 example 样板,**请勿在此写真实主机名 / 账号 / 密码**。
#     真实配置请复制到 config.yaml(已在 .gitignore 里)再填本地或私有环境。
#   - 任何提交到 git 的样例都必须用占位符(example.com / localhost / 空字符串)。
#   - 线上密钥走环境变量或密管,不进文件。

server:
  http:
    addr: 0.0.0.0:6039
    timeout: 1000s
  grpc:
    addr: 0.0.0.0:9000
    timeout: 1000s

data:
  # MySQL:本地 docker-compose 起或自己填远程地址
  database:
    driver: mysql
    source: user:password@tcp(mysql.example.com:3306)/opslabs?parseTime=True&loc=Local
  # PostgreSQL:可选,不用就整段留空
  pg_database:
    host: postgres.example.com
    port: 5432
    user: ""
    password: ""
    dbname: opslabs
    sslmode: disable
  # Redis:AttemptStore 必需
  redis:
    addr: redis.example.com:6379
    read_timeout: 0.2s
    write_timeout: 0.2s
    password: ""

log:
  maxAge: 30
  level: "debug"
  format: "console"
  director: "./logs"
  encodeLevel: "CapitalColorLevelEncoder"

# 第三方登录(V1 未启用,留空即可)
auth:
  qq:
    app_id: ""
    app_key: ""
    callback_url: ""
    frontend_redirect: "http://localhost:5173/chat"
    scope: "get_user_info"

# 站内信 / 邮件(选用)
beta:
  mail:
    host: ""
    port: 587
    username: ""
    password: ""
    to: ""
    from: ""

# 对象存储(选用,MinIO / 阿里 OSS 等)
oss:
  access_key: ""
  secret_key: ""

# opslabs 场景运行时配置
#
# driver:
#   - docker (默认/生产):docker run 真容器,HostPort 为真实映射端口
#   - mock (测试):不启容器、不占端口,HostPort=0,前端会识别为"预览模式"
#     仅用于无 Docker Desktop 本机冒烟 API 契约;线上请勿使用
runtime:
  driver: docker
  port_start: 10000
  port_end: 19999
  terminal_host: localhost
  terminal_url_template: "http://{host}:{port}/"
  default_idle_timeout: 1800s
  reaper_interval: 60s
