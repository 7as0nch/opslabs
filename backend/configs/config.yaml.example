server:
  http:
    addr: 0.0.0.0:6039
    timeout: 1000s
  grpc:
    addr: 0.0.0.0:9000
    timeout: 1000s
data:
  database:
    driver: mysql
    source: read_rentianhua:@tcp(rm-.mysql.rds.aliyuncs.com:3306)/rth?parseTime=True&loc=Local
  pg_database:
    host: sshjd.aihelper.chat
    port: 30532
    user:
    password: ""
    dbname: pgdb
    sslmode: disable
  redis:
    addr: sshjd.aihelper.chat:30379
    read_timeout: 0.2s
    write_timeout: 0.2s
    password: ""

log:
  maxAge: 30
  level: "debug"
  format: "console"
  director: "./logs"
  encodeLevel: "CapitalColorLevelEncoder"

auth:
  qq:
    app_id: ""
    app_key: ""
    callback_url: ""
    frontend_redirect: "http://localhost:5173/chat"
    scope: "get_user_info"

beta:
  mail:
    host: ""
    port: 587
    username: ""
    password: ""
    to: ""
    from: ""

# TODO minio 配置
oss:
  access_key: ""
  secret_key: ""

# opslabs 场景运行时配置
#
# driver:
#   - docker (默认/生产):docker run 真容器,HostPort 为真实映射端口
#   - mock (测试):不启容器、不占端口,HostPort=0,前端会识别为"预览模式"
#     仅用于无 Docker Desktop 本机冒烟 API 契约;线上请勿使用
runtime:
  driver: docker
  port_start: 10000
  port_end: 19999
  terminal_host: localhost
  terminal_url_template: "http://{host}:{port}/"
  default_idle_timeout: 1800s
  reaper_interval: 60s
